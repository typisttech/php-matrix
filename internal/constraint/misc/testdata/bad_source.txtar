! exec php-matrix constraint  '^7' --source=bad
! stdout .
cmp stderr stderr.golden

-- stderr.golden --

                                                                                                            
  The value "bad" is not valid for the "source" option. Supported values are "auto", "php.net", "offline".  
                                                                                                            

constraint [--source SOURCE] [--mode MODE] [--] <constraint>

