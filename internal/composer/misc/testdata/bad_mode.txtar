! exec php-matrix composer --mode=bad
! stdout .
cmp stderr stderr.golden

-- stderr.golden --

                                                                                                  
  The value "bad" is not valid for the "mode" option. Supported values are "full", "minor-only".  
                                                                                                  

composer [--source SOURCE] [--mode MODE] [--] [<path>]

